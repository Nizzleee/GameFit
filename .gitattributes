# Normalize line endings for all text files
* text=auto

# Force Unix line endings for shell scripts
gradlew text eol=lf

# Force Windows line endings for batch files
gradlew.bat text eol=crlf

# Binary files — no line-ending conversion
*.webp binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.apk  binary
*.aar  binary
*.aab  binary
*.jks  binary
*.keystore binary
